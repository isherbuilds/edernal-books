{
  "name": "@tsu-stack/db",
  "private": true,
  "type": "module",
  "imports": {
    "#@/*": "./src/*.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./migrate": "./src/migrate.ts",
    "./queries": "./src/queries/index.ts",
    "./schema": "./src/schema/index.ts",
    "./utils/health": "./src/utils/health.ts"
  },
  "scripts": {
    "db": "vpx dotenvx run -f ../env/.env -- drizzle-kit",
    "db:dev:start": "docker compose -f docker-compose.dev.yaml up -d",
    "db:dev:stop": "docker compose -f docker-compose.dev.yaml stop",
    "db:seed": "vpx dotenvx run -f ../env/.env -- node --import tsx src/seed.ts",
    "auth:generate": "vp run -w auth:generate",
    "test:unit": "vp test",
    "test:integration": "NODE_ENV=development DB_INTEGRATION_TESTS=1 vpx dotenvx run -f ../env/.env -- vp test src/queries/*.integration.test.ts"
  },
  "dependencies": {
    "@tsu-stack/core": "workspace:*",
    "@tsu-stack/logger": "workspace:*",
    "drizzle-orm": "catalog:",
    "postgres": "catalog:",
    "uuid": "catalog:"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "catalog:",
    "@tsu-stack/env": "workspace:*",
    "@tsu-stack/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "drizzle-kit": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "@tanstack/react-start": "catalog:"
  }
}
